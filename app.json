{
  "expo": {
    "name": "DermaImageRecords",
    "slug": "dermaimagerecords",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dermaimagerecords",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dermaimagerecords.dermaimagerecords"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "@react-native-google-signin/google-signin",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow DermaImageRecords to use the microphone so you can dictate consultation remarks.",
          "speechRecognitionPermission": "Allow DermaImageRecords to use speech recognition so you can dictate consultation remarks.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1262cd3c-e2c8-4428-b6f7-ffe08c7730fa"
      },
      "supabaseUrl": "https://ehryrcsdgibnjnmddyrm.supabase.co",
      "supabaseAnonKey": "sb_publishable_jXMZmRbVYrpY2Pw6qB10UQ_lWbfZfZI",
      "googleWebClientId": "541186667754-0294gm2i37l78bdd944avj9ujct7qn91.apps.googleusercontent.com",
      "googleAndroidClientId": "541186667754-r7tg9csduqn5vcan12i8n14vn6mj234s.apps.googleusercontent.com"
    },
    "owner": "gunakar-challa"
  }
}
