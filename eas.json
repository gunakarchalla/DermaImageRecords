{
    "cli": {
        "version": ">= 7.3.0",
        "appVersionSource": "remote"
    },
    "build": {
        "preview": {
            "android": {
                "buildType": "apk",
                "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a"
            }
        },
        "production": {
            "autoIncrement": true,
            "android": {
                "buildType": "apk",
                "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a"
            }
        }
    }
}
